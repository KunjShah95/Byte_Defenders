# =============================================================================
# Byte Defenders - Multi-Agent Creative Studio
# Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=3000
NODE_ENV=development
HOST=localhost
LOG_LEVEL=info

# =============================================================================
# AI/GENAI SERVICE CONFIGURATION
# =============================================================================
# Provider options: openai | google | mock
GENAI_PROVIDER=google

# For Google Gemini (recommended)
# Get a free API key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# For OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Advanced GenAI settings (optional)
# GENAI_BASE_URL=https://api.openai.com/v1
# GENAI_MODEL=gemini-2.0-pro-preview
# GENAI_FALLBACK_TO_MOCK=true

# =============================================================================
# DATABASE - SUPABASE (Optional - defaults to in-memory)
# =============================================================================
# PERSISTENCE_MODE options: memory | redis | postgres | supabase
PERSISTENCE_MODE=memory

# Supabase (for production persistence)
# Create a free project at: https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# =============================================================================
# FIREBASE AUTH (Required for API authentication)
# =============================================================================
# Create a Firebase project and download service account JSON at:
# https://console.firebase.google.com
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_PRIVATE_KEY="your-firebase-private-key"

# =============================================================================
# REDIS CACHE (Optional - for caching layer)
# =============================================================================
# REDIS_HOST=localhost
# REDIS_PORT=6379

# =============================================================================
# POSTGRESQL DATABASE (Optional - alternative to Supabase)
# =============================================================================
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=creative_studio
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres

# =============================================================================
# CORS & SECURITY
# =============================================================================
CORS_ORIGIN=http://localhost:5173,http://localhost:5175,http://localhost:8080

# Rate limiting (requests per window)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# MOTI BACKEND (Optional - secondary AI backend)
# =============================================================================
# MOTI_ENABLED=false
# MOTI_API_KEY=
# MOTI_BASE_URL=http://localhost:8000

# =============================================================================
# ADVANCED OPTIONS
# =============================================================================
# METRICS_ENABLED=true
# METRICS_PORT=9090
